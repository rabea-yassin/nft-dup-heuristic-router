# --- Reference papers / documents ---
*.pdf

# --- Large image datasets & raw NFT assets ---
# Everything under data/ is ignored except data/example/, a small,
# git-tracked subset (public Kaggle-sourced images only) that shows the
# data layout without shipping the full corpus.
data/*
!data/example/
*.png
*.jpg
*.jpeg
*.bmp
*.tiff
*.webp
*.gif
*.npy
*.npz
*.zip
*.tar
*.tar.gz
*.7z
!data/example/**/*.png

# --- Bare-metal build artifacts ---
build/
bin/
out/
*.o
*.obj
*.out
*.a
*.so
*.dll
*.exe
*.elf
*.map
*.d

# --- Logs ---
logs/
*.log

# --- Deploy key (repo-scoped SSH auth, never commit) ---
.deploy_key/

# --- Personal working notes, local-only ---
NEXT_STEPS.md
NOTES_TO_SELF.md
PLAN.md

# --- Editor / OS cruft ---
.vscode/
.idea/
*.swp
.DS_Store

# --- Python (offline training scripts, if any) ---
__pycache__/
*.pyc
.venv/
venv/
